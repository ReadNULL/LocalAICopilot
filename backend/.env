# ==========================================
# 基础项目配置
# ==========================================
PROJECT_NAME="Local AI Copilot"

# ==========================================
# 本地大模型部署配置 (Ollama)
# ==========================================
# Ollama 默认运行在本地的 11434 端口
OLLAMA_BASE_URL="http://localhost:11434"

# 填入你实际通过 ollama pull 下载的 LLM 模型名称（例如：qwen2.5:latest 或 llama3:latest）
LLM_MODEL_NAME="qwen2.5"

# 填入你实际通过 ollama pull 下载的 Embedding 模型名称
# 注：README 中提到的 bge-large-zh-v1.5，在 Ollama 中对应的仓库标签通常是 bge-large
EMBEDDING_MODEL_NAME="bge-large"

# ==========================================
# 本地重排模型配置 (Sentence-Transformers)
# ==========================================
# 第一次运行时，代码会根据这个名称去 Hugging Face 自动下载模型权重
RERANK_MODEL_NAME="BAAI/bge-reranker-v2-m3"

# ==========================================
# 向量数据库配置 (Qdrant)
# ==========================================
# Qdrant Docker 容器默认映射的 REST API 端口是 6333
QDRANT_URL="http://localhost:6333"

# 如果你在 docker-compose.yml 中没有为 Qdrant 设置鉴权，这里保持为空即可
QDRANT_API_KEY=""

# ==========================================
# RAG 策略高级配置 (通常不需要修改，保持默认即可)
# ==========================================
CHUNK_SIZE=256
CHUNK_OVERLAP_PERCENT=0.15
RETRIEVER_TOP_K=20
RERANK_TOP_K=5
MAX_RETRIES=3